NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI vision/IFS provider. Default: Gemini (Google AI Studio free tier).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: gemini-2.0-flash (default) | gemini-2.5-flash
GEMINI_MODEL=

# Optional fallback provider. Leave AI_PROVIDER unset to auto-pick Gemini.
# AI_PROVIDER=gemini|anthropic
ANTHROPIC_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000
